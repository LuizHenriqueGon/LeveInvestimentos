@model LeveInvestimentos.Web.ViewModels.UsuarioViewModel

@{
    ViewData["Title"] = "Cadastrar Usuário";
}

<div class="uk-container uk-margin-top uk-animation-slide-bottom-small">
    <div class="uk-card uk-card-default uk-card-body uk-box-shadow-large uk-border-rounded">
        <h2 class="uk-card-title uk-heading-divider">Cadastrar Novo Usuário</h2>

        <form asp-action="Cadastrar" method="post" enctype="multipart/form-data" class="uk-form-stacked">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="uk-alert-danger" uk-alert>
                    <a class="uk-alert-close" uk-close></a>
                    @Html.ValidationSummary(false, "", new { @class = "uk-list uk-margin-remove" })
                </div>
            }

            <div class="uk-grid-small uk-child-width-1-2@s" uk-grid>
                <div>
                    <label class="uk-form-label uk-text-bold">Nome Completo</label>
                    <input asp-for="NomeCompleto" class="uk-input uk-border-rounded" placeholder="Ex: Renato Silva" required />
                </div>
                <div>
                    <label class="uk-form-label uk-text-bold">E-mail</label>
                    <input asp-for="Email" type="email" class="uk-input uk-border-rounded" placeholder="email@leveinvestimentos.com.br" required />
                </div>
            </div>

            <div class="uk-grid-small uk-child-width-1-3@s uk-margin" uk-grid>
                <div>
                    <label class="uk-form-label uk-text-bold">Data de Nascimento</label>
                    <input asp-for="DataNascimento" type="date" class="uk-input uk-border-rounded" required />
                </div>
                <div>
                    <label class="uk-form-label uk-text-bold">Telefone Fixo</label>
                    <input asp-for="TelefoneFixo" class="uk-input uk-border-rounded" placeholder="(11) 2537-7777" />
                </div>
                <div>
                    <label class="uk-form-label uk-text-bold">Telefone Celular</label>
                    <input asp-for="TelefoneCelular" class="uk-input uk-border-rounded" placeholder="(11) 99999-9999" required />
                </div>
            </div>

            <div class="uk-margin">
                <label class="uk-form-label uk-text-bold">Endereço Completo</label>
                <input asp-for="Endereco" class="uk-input uk-border-rounded" placeholder="Praça Maastricht, nº 200..." required />
            </div>

            <div class="uk-grid-small uk-child-width-1-2@s uk-margin" uk-grid>
                <div>
                    <label class="uk-form-label uk-text-bold">Senha de Acesso</label>
                    <input asp-for="Senha" type="password" class="uk-input uk-border-rounded" required />
                </div>
                <div class="uk-flex uk-flex-middle" style="margin-top: 35px;">
                    <label><input asp-for="IsGestor" class="uk-checkbox" type="checkbox"> <strong>Perfil de Gestor?</strong></label>
                </div>
            </div>

            <div class="uk-margin">
                <label class="uk-form-label uk-text-bold">Foto do Funcionário</label>
                <div uk-form-custom="target: true" class="uk-width-1-1">
                    <input asp-for="FotoArquivo" type="file" accept="image/*" required>
                    <input class="uk-input uk-width-1-1 uk-border-rounded" type="text" placeholder="Clique aqui para selecionar a foto do computador..." readonly>
                </div>
            </div>

            <div class="uk-margin-medium-top">
                <button type="submit" class="uk-button uk-button-primary uk-border-rounded">Salvar Usuário</button>
                <a asp-action="Listar" class="uk-button uk-button-default uk-border-rounded">Cancelar</a>
            </div>
        </form>
    </div>
</div>
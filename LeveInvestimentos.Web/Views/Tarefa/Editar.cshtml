@model LeveInvestimentos.Core.Entities.Tarefa

@{
    ViewData["Title"] = "Editar Tarefa";
}

<div class="uk-container uk-margin-top uk-animation-slide-bottom-small">
    <div class="uk-card uk-card-default uk-card-body uk-box-shadow-large uk-border-rounded">
        <h2 class="uk-card-title uk-heading-divider">Editar Tarefa</h2>

        <form asp-action="Editar" method="post" class="uk-form-stacked">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="GestorId" />

            <div class="uk-margin">
                <label class="uk-form-label uk-text-bold">Mensagem Descritiva</label>
                <div class="uk-form-controls">
                    <textarea asp-for="MensagemDescritiva" class="uk-textarea uk-border-rounded" rows="4" required></textarea>
                </div>
            </div>

            <div class="uk-grid-small uk-child-width-1-3@s" uk-grid>
                <div>
                    <label class="uk-form-label uk-text-bold">Data Limite</label>
                    <div class="uk-form-controls">
                        <input asp-for="DataLimite" type="datetime-local" class="uk-input uk-border-rounded" required />
                    </div>
                </div>
                <div>
                    <label class="uk-form-label uk-text-bold">Colaborador Responsável</label>
                    <div class="uk-form-controls">
                        <select asp-for="SubordinadoId" class="uk-select uk-border-rounded" required>
                            <option value="">Selecione o subordinado...</option>
                            @if (ViewBag.Subordinados != null)
                            {
                                foreach (var sub in ViewBag.Subordinados)
                                {
                                    <option value="@sub.Id">@sub.NomeCompleto</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div>
                    <label class="uk-form-label uk-text-bold">Status da Tarefa</label>
                    <div class="uk-form-controls">
                        <select asp-for="StatusTarefa" class="uk-select uk-border-rounded" required>
                            <option value="Pendente">Pendente</option>
                            <option value="Em Andamento">Em Andamento</option>
                            <option value="Concluída">Concluída</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="uk-margin-medium-top">
                <button type="submit" class="uk-button uk-button-primary uk-border-rounded">Salvar Alterações</button>
                <a asp-action="Listar" class="uk-button uk-button-default uk-border-rounded">Cancelar</a>
            </div>
        </form>
    </div>
</div>